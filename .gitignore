# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files (never commit secrets — .env.local.example is the only tracked template)
.env
.env.*
!.env.local.example

# vercel
.vercel

# claude code local state — machine/session-specific, not project code
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts
